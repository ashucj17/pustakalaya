{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "p-white", "color": "#fff", "name": "Pustakalaya White" },
        {
          "slug": "p-gray-100",
          "color": "rgb(243 244 246)",
          "name": "Pustakalaya Gray 100"
        },
        {
          "slug": "p-gray-200",
          "color": "rgb(229 231 235)",
          "name": "Pustakalaya Gray 200"
        },
        {
          "slug": "p-gray-300",
          "color": "rgb(209 213 219)",
          "name": "Pustakalaya Gray 300"
        },
        {
          "slug": "p-gray-400",
          "color": "rgb(156 163 175)",
          "name": "Pustakalaya Gray 400"
        },
        {
          "slug": "p-gray-500",
          "color": "rgb(107 114 128)",
          "name": "Pustakalaya Gray 500"
        },
        {
          "slug": "p-gray-600",
          "color": "rgb(75 85 99)",
          "name": "Pustakalaya Gray 600"
        },
        {
          "slug": "p-gray-700",
          "color": "rgb(55 65 81)",
          "name": "Pustakalaya Gray 700"
        },
        {
          "slug": "p-gray-800",
          "color": "rgb(31 41 55)",
          "name": "Pustakalaya Gray 800"
        },
        {
          "slug": "p-gray-900",
          "color": "rgb(17 24 39)",
          "name": "Pustakalaya Gray 900"
        },
        {
          "slug": "p-primary",
          "color": "rgb(255 255 0)",
          "name": "Pustakalaya Primary"
        },
        {
          "slug": "p-accent",
          "color": "rgb(67 56 202)",
          "name": "Pustakalaya Accent"
        },
        {
          "slug": "p-success",
          "color": "rgb(52 211 153)",
          "name": "Pustakalaya Success"
        },
        {
          "slug": "p-info",
          "color": "rgb(96 165 250)",
          "name": "Pustakalaya Info"
        },
        {
          "slug": "p-warning",
          "color": "rgb(251 146 60)",
          "name": "Pustakalaya Warning"
        },
        {
          "slug": "p-danger",
          "color": "rgb(236 72 153)",
          "name": "Pustakalaya Danger"
        }
      ],
      "link": true,
      "custom": true,
      "duotone": [
        {"slug": "p-pink-sunset", "colors": ["#11245e", "#dc4379"], "name": "Pustakalaya Pink Sunset"}
      ],
      "defaultGradients": false,
      "gradients": [{
        "slug": "p-summer-book",
        "name": "Pustakalaya Summer Book",
        "gradient": "linear-gradient(#fcb900, #78ffd6)"
      }]
    },
    "blocks": {
      "core/site-title": {
        "color": {
          "defaultPalette": true,
          "palette": [
            {
              "slug": "p-primary",
              "color": "#ffff00",
              "name": "Pustakalaya Primary"
            }
          ],
          "link": true,
          "custom": false,
          "gradients": [],
          "customGradient": false
        },
        "core.cover": {
            "color": {
                "duotone": [],
                "customDuotone": false
            }
        }
      }
    }
  },
  "styles": {
    "color": {
        "text": "var(--wp--preset--color--p-gray-700)",
        "background": "var(--wp-preset--color--p-white)"
    },
    "blocks":{
        "core/button": {
            "color": {
                "text": "var(--wp--preset--color--p-gray-700)",
                "gradient": "var(--wp--preset--gradient--p-summer-book)"
            }
        }
    }
  }
}
