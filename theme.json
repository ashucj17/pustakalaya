{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,

  "settings": {
    "appearanceTools": true,

    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "white", "color": "#ffffff", "name": "White" },
        { "slug": "gray-100", "color": "#f3f4f6", "name": "Gray 100" },
        { "slug": "gray-200", "color": "#e5e7eb", "name": "Gray 200" },
        { "slug": "gray-300", "color": "#d1d5db", "name": "Gray 300" },
        { "slug": "gray-400", "color": "#9ca3af", "name": "Gray 400" },
        { "slug": "gray-500", "color": "#6b7280", "name": "Gray 500" },
        { "slug": "gray-600", "color": "#4b5563", "name": "Gray 600" },
        { "slug": "gray-700", "color": "#374151", "name": "Gray 700" },
        { "slug": "gray-800", "color": "#1f2937", "name": "Gray 800" },
        { "slug": "gray-900", "color": "#111827", "name": "Gray 900" },

        { "slug": "primary", "color": "#eab308", "name": "Primary" },
        { "slug": "accent", "color": "#4338ca", "name": "Accent" },
        { "slug": "success", "color": "#34d399", "name": "Success" },
        { "slug": "info", "color": "#60a5fa", "name": "Info" },
        { "slug": "warning", "color": "#fb923c", "name": "Warning" },
        { "slug": "danger", "color": "#ec4899", "name": "Danger" }
      ],

      "duotone": [
        {
          "slug": "pink-sunset",
          "colors": ["#11245e", "#dc4379"],
          "name": "Pink Sunset"
        }
      ],

      "gradients": [
        {
          "slug": "summer",
          "name": "Summer Gradient",
          "gradient": "linear-gradient(135deg, #fcb900, #78ffd6)"
        }
      ]
    },

    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Rubik, sans-serif",
          "slug": "rubik",
          "name": "Rubik"
        },
        {
          "fontFamily": "Pacifico, cursive",
          "slug": "pacifico",
          "name": "Pacifico"
        }
      ],

      "fontSizes": [
        { "slug": "xs", "size": "0.75rem", "name": "XS" },
        { "slug": "sm", "size": "0.875rem", "name": "Small" },
        { "slug": "md", "size": "1rem", "name": "Medium" },
        { "slug": "lg", "size": "1.5rem", "name": "Large" },
        { "slug": "xl", "size": "2.25rem", "name": "XL" },
        { "slug": "2xl", "size": "3rem", "name": "2XL" }
      ],

      "lineHeight": true,
      "letterSpacing": true,
      "textTransform": true,
      "textDecoration": true
    },

    "spacing": {
      "units": ["px", "rem", "%", "vh", "vw"],
      "blockGap": true,
      "margin": true,
      "padding": true
    },

    "layout": {
      "contentSize": "800px",
      "wideSize": "1200px"
    },

    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },

    "blocks": {
      "core/site-title": {
        "typography": {
          "fontFamilies": [
            {
              "fontFamily": "Pacifico, cursive",
              "slug": "pacifico",
              "name": "Pacifico"
            }
          ]
        }
      },

      "core/cover": {
        "color": {
          "duotone": []
        }
      },

      "core/preformatted": {
        "typography": {
          "customFontSize": true
        }
      }
    }
  },

  "styles": {
    "color": {
      "text": "var(--wp--preset--color--gray-700)",
      "background": "var(--wp--preset--color--white)"
    },

    "typography": {
      "fontFamily": "var(--wp--preset--font-family--rubik)",
      "fontSize": "16px",
      "lineHeight": "1.6"
    },

    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      }
    },

    "blocks": {
      "core/button": {
        "color": {
          "text": "var(--wp--preset--color--gray-700)",
          "background": "var(--wp--preset--gradient--summer)"
        },
        "border": {
          "radius": "6px"
        }
      },

      "core/pullquote": {
        "border": {
          "width": "2px",
          "style": "solid",
          "color": "var(--wp--preset--color--primary)",
          "radius": "8px"
        }
      },

      "core/site-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--pacifico)"
        }
      }
    },

    "spacing": {
      "blockGap": "2rem",
      "padding": {
        "top": "0",
        "bottom": "0",
        "left": "0",
        "right": "0"
      }
    }
  }
}