{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,

  "settings": {
    "appearanceTools": true,

    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "white",       "color": "#ffffff", "name": "White" },
        { "slug": "black",       "color": "#111111", "name": "Black" },
        { "slug": "yellow",      "color": "#efe117", "name": "Pustak Yellow" },
        { "slug": "red",         "color": "#ad0b0b", "name": "Pustak Red" },
        { "slug": "gray-light",  "color": "#ededed", "name": "Gray Light" },
        { "slug": "gray-mid",    "color": "#666666", "name": "Gray Mid" },
        { "slug": "gray-dark",   "color": "#444444", "name": "Gray Dark" },
        { "slug": "tag-orange",  "color": "#ff9944", "name": "Tag Orange" }
      ],

      "gradients": [
        {
          "slug": "yellow-light",
          "name": "Yellow Light",
          "gradient": "linear-gradient(135deg, #efe117 0%, #fff9aa 100%)"
        }
      ]
    },

    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "\"Segoe UI\", Tahoma, Geneva, Verdana, sans-serif",
          "slug": "segoe",
          "name": "Segoe UI"
        },
        {
          "fontFamily": "Rubik, sans-serif",
          "slug": "rubik",
          "name": "Rubik"
        },
        {
          "fontFamily": "Pacifico, cursive",
          "slug": "pacifico",
          "name": "Pacifico"
        }
      ],

      "fontSizes": [
        { "slug": "xs",  "size": "0.75rem",  "name": "XS" },
        { "slug": "sm",  "size": "0.875rem", "name": "Small" },
        { "slug": "md",  "size": "1rem",     "name": "Medium" },
        { "slug": "lg",  "size": "1.2rem",   "name": "Large" },
        { "slug": "xl",  "size": "1.75rem",  "name": "XL" },
        { "slug": "2xl", "size": "2.5rem",   "name": "2XL" },
        { "slug": "3xl", "size": "3.5rem",   "name": "3XL" }
      ],

      "lineHeight": true,
      "letterSpacing": true,
      "textTransform": true,
      "textDecoration": true
    },

    "spacing": {
      "units": ["px", "rem", "%", "vh", "vw"],
      "blockGap": true,
      "margin": true,
      "padding": true
    },

    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },

    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },

    "blocks": {
      "core/site-title": {
        "typography": {
          "fontFamilies": [
            {
              "fontFamily": "Pacifico, cursive",
              "slug": "pacifico",
              "name": "Pacifico"
            }
          ]
        }
      }
    }
  },

  "styles": {
    "color": {
      "text": "var(--wp--preset--color--black)",
      "background": "var(--wp--preset--color--white)"
    },

    "typography": {
      "fontFamily": "var(--wp--preset--font-family--segoe)",
      "fontSize": "16px",
      "lineHeight": "1.6"
    },

    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--black)"
        }
      },
      "h1": { "typography": { "fontSize": "var(--wp--preset--font-size--3xl)", "fontWeight": "700" } },
      "h2": { "typography": { "fontSize": "var(--wp--preset--font-size--xl)",  "fontWeight": "700" } },
      "h3": { "typography": { "fontSize": "var(--wp--preset--font-size--lg)",  "fontWeight": "600" } }
    },

    "blocks": {
      "core/button": {
        "color": {
          "text": "var(--wp--preset--color--white)",
          "background": "var(--wp--preset--color--red)"
        },
        "border": {
          "radius": "4px"
        },
        "typography": {
          "fontWeight": "700"
        }
      },

      "core/navigation": {
        "typography": {
          "fontWeight": "700",
          "textTransform": "uppercase"
        },
        "color": {
          "text": "var(--wp--preset--color--black)"
        }
      },

      "core/site-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--pacifico)"
        }
      }
    },

    "spacing": {
      "blockGap": "2rem",
      "padding": {
        "top": "0",
        "bottom": "0",
        "left": "0",
        "right": "0"
      }
    }
  },

  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],

  "customTemplates": [
    {
      "name": "front-page",
      "title": "Front Page",
      "postTypes": ["page"]
    }
  ]
}